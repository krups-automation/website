# Sanity read token — for fetching draft (unpublished) content on the server.
# Create at: https://www.sanity.io/manage/project/8075qdie/api#tokens
# Permissions: "Viewer" (read-only)
SANITY_API_READ_TOKEN=

# Shared secret that protects the /api/preview endpoint (server side).
# Generate with: openssl rand -hex 32
SANITY_PREVIEW_SECRET=

# Same value as SANITY_PREVIEW_SECRET above, exposed to the Sanity Studio
# bundle so its "Preview" button can construct a valid /api/preview URL.
# (Studio is gated behind Sanity auth, so "public" here is acceptable.)
PUBLIC_PREVIEW_SECRET=
