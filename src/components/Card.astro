---
interface Props {
  href?: string;
  class?: string;
  padding?: 'sm' | 'md' | 'lg';
}

const { href, class: className, padding = 'md', ...rest } = Astro.props;
const Tag = href ? 'a' : 'div';
const classes = ['card', `card-pad-${padding}`, href && 'card-link', className].filter(Boolean).join(' ');
---

{Tag === 'a' ? (
  <a href={href} class={classes} {...rest}><slot /></a>
) : (
  <div class={classes} {...rest}><slot /></div>
)}

<style>
  .card {
    display: block;
    background: var(--color-bg);
    border: var(--border-hairline);
    border-radius: var(--radius-lg);
    transition: border-color var(--duration-short);
    color: inherit;
  }

  .card-pad-sm { padding: var(--space-4); }
  .card-pad-md { padding: var(--space-6); }
  .card-pad-lg { padding: var(--space-8); }

  .card-link:hover,
  .card-link:focus-visible {
    border-color: var(--color-accent);
  }
</style>
