---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
---

<BaseLayout title="KRUPS Automation — Phase 1" locale="de">
  <div class="page">
    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Phase 1 · Block D' }]} />

    <span class="label">Smoke test · BaseLayout + Header + Footer</span>
    <h1>KRUPS Automation</h1>
    <h2>Editorial Industrial, precise and warm.</h2>
    <p>
      Base layout in place. The floating header above pulls nav items from
      Sanity <code>siteSettings</code> (or falls back to hardcoded German defaults
      if no content exists yet). Footer is dark with 4-column grid and bottom bar.
    </p>

    <div class="specs">
      <div class="spec"><span class="spec-k">Payload</span><span class="spec-v">2.000 kg</span></div>
      <div class="spec"><span class="spec-k">Precision</span><span class="spec-v">±0,1 mm</span></div>
      <div class="spec"><span class="spec-k">Voltage</span><span class="spec-v">400 V / 50 Hz</span></div>
    </div>

    <div class="swatches" aria-label="color swatches">
      <span class="swatch" style="background: var(--color-bg)">Paper</span>
      <span class="swatch" style="background: var(--color-surface)">Clay</span>
      <span class="swatch dark" style="background: var(--color-dark-bg)">Charcoal</span>
      <span class="swatch dark" style="background: var(--color-accent)">Yellow</span>
    </div>
  </div>
</BaseLayout>

<style>
  .page {
    max-width: var(--content-max);
    margin: 0 auto;
    padding: 140px var(--space-12) var(--space-24);
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .page h2 {
    color: var(--color-muted);
    max-width: 20ch;
  }

  code {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: var(--color-surface);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
  }

  .specs {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    border-top: var(--border-hairline);
    border-bottom: var(--border-hairline);
    padding: var(--space-4) 0;
    max-width: 480px;
  }

  .spec {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: var(--font-size-specs);
  }

  .spec-k {
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    font-size: var(--font-size-label);
  }

  .swatches {
    display: flex;
    gap: var(--space-2);
    margin-top: var(--space-4);
  }

  .swatch {
    padding: var(--space-4) var(--space-6);
    border-radius: var(--radius-md);
    font-family: var(--font-mono);
    font-size: var(--font-size-label);
    letter-spacing: 1.5px;
    text-transform: uppercase;
    border: var(--border-hairline);
  }

  .swatch.dark {
    color: var(--color-dark-text);
  }
</style>
