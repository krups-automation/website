---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Section from '../components/Section.astro';
import Card from '../components/Card.astro';
import Button from '../components/Button.astro';
import Badge from '../components/Badge.astro';
---

<BaseLayout title="KRUPS Automation — Phase 1" locale="de">
  <div class="hero-spacer"></div>

  <Section surface="paper">
    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Phase 1 · Block E' }]} />

    <div class="hero-head">
      <Badge>Smoke test · UI primitives</Badge>
      <h1>KRUPS Automation</h1>
      <h2>Editorial Industrial, precise and warm.</h2>
      <p>
        Phase 1 foundation — BaseLayout, floating nav, dark footer, design tokens,
        self-hosted fonts, embedded Sanity Studio, and now shared UI primitives
        (Button, Card, Badge, Section).
      </p>
      <div class="cta-row">
        <Button variant="primary" href="/admin">Open Studio</Button>
        <Button variant="dark" href="#systems">See Systems</Button>
        <Button variant="ghost" href="#contact">Talk to an Engineer</Button>
      </div>
    </div>
  </Section>

  <Section surface="clay" id="systems">
    <h3>Card primitive</h3>
    <div class="card-grid">
      <Card href="#">
        <Badge variant="accent">Flagship</Badge>
        <h4>LOGO!MAT eCart</h4>
        <p>Self-driving rail-guided carts for flexible assembly lines.</p>
      </Card>
      <Card href="#">
        <Badge>Proven</Badge>
        <h4>Friktionsförderer L/XL</h4>
        <p>Friction roller conveyors for up to 2.000 kg payload.</p>
      </Card>
      <Card href="#">
        <Badge>Precision</Badge>
        <h4>T-Serie Taktförderer</h4>
        <p>Indexing conveyors with ±0,1 mm stop accuracy.</p>
      </Card>
    </div>
  </Section>

  <Section surface="charcoal" id="contact">
    <div class="dark-cta">
      <Badge variant="accent">Ready</Badge>
      <h2>Start a conversation.</h2>
      <p>Tell us about your production line — we'll reply with an engineer, not a salesperson.</p>
      <div class="cta-row">
        <Button variant="primary" href="#">Request a Project</Button>
        <Button variant="ghost-light" href="#">Download Brochure</Button>
      </div>
    </div>
  </Section>
</BaseLayout>

<style>
  .hero-spacer {
    height: 100px;
  }

  .hero-head {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-6);
    padding-top: var(--space-6);
  }

  .hero-head h2 {
    color: var(--color-muted);
    max-width: 20ch;
  }

  .hero-head p {
    max-width: 56ch;
  }

  .cta-row {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-top: var(--space-4);
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
    margin-top: var(--space-8);
  }

  .card-grid h4 {
    margin-top: var(--space-4);
  }

  .card-grid p {
    margin-top: var(--space-2);
    color: var(--color-muted);
    font-size: var(--font-size-body-sm);
  }

  .dark-cta {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-4);
  }

  .dark-cta p {
    max-width: 56ch;
    color: var(--color-dark-muted);
  }

  @media (max-width: 900px) {
    .card-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
