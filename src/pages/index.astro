---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="KRUPS Automation — LOGO!MAT eCart" locale="de">
  <!-- ════ 1. HERO ════ -->
  <section class="hero">
    <div class="hero-fade"></div>
    <div class="hero-content">
      <div class="hero-eyebrow">LOGO!MAT eCart — Engineered in Hilden, Germany</div>
      <h1>Built for <em>the line</em> that never stops.</h1>
      <p class="hero-sub">
        Rail-guided conveyor systems for precision automotive assembly —
        from battery modules to drivetrains, trusted by the world's leading manufacturers.
      </p>
      <div class="hero-ctas">
        <a href="#systems" class="btn btn-dark">See Our Systems →</a>
        <a href="#contact" class="btn btn-ghost">Talk to an Engineer</a>
      </div>
      <div class="hero-stats">
        <div class="hero-stat"><span class="val">500+</span><span class="lbl">Installations</span></div>
        <div class="hero-stat-sep"></div>
        <div class="hero-stat"><span class="val">300 – 2.000 kg</span><span class="lbl">Payload Range</span></div>
        <div class="hero-stat-sep"></div>
        <div class="hero-stat"><span class="val">±0,1 mm</span><span class="lbl">Stop Accuracy</span></div>
        <div class="hero-stat-sep"></div>
        <div class="hero-stat"><span class="val">40+</span><span class="lbl">Years</span></div>
      </div>
    </div>
  </section>

  <!-- ════ 2. TRUST BAR ════ -->
  <div class="trust-bar">
    <div class="trust-bar-inner">
      <span class="trust-bar-label">Trusted by</span>
      <div class="trust-sep"></div>
      <div class="trust-logos">
        <span class="trust-logo">BMW</span>
        <span class="trust-logo">Volkswagen</span>
        <span class="trust-logo">Mercedes-Benz</span>
        <span class="trust-logo">Tesla</span>
        <span class="trust-logo">Porsche</span>
        <span class="trust-logo">Audi</span>
        <span class="trust-logo">Lamborghini</span>
        <span class="trust-logo">ZF</span>
        <span class="trust-logo">Kärcher</span>
      </div>
    </div>
  </div>

  <!-- ════ 3. PROOF STATS ════ -->
  <section class="proof-alt">
    <div class="container">
      <div class="proof-alt-strip">
        <div class="proof-alt-item">
          <span class="proof-alt-num">500+</span>
          <span class="proof-alt-label">Systems installed<br>worldwide</span>
        </div>
        <div class="proof-alt-item">
          <span class="proof-alt-num">40+</span>
          <span class="proof-alt-label">Years of engineering<br>experience</span>
        </div>
        <div class="proof-alt-item">
          <span class="proof-alt-num">2.000 kg</span>
          <span class="proof-alt-label">Maximum<br>payload capacity</span>
        </div>
        <div class="proof-alt-item">
          <span class="proof-alt-num">14</span>
          <span class="proof-alt-label">Countries with<br>active installations</span>
        </div>
      </div>

      <div class="proof-alt-bottom">
        <h2 class="proof-headline">Forty years of assembly line engineering.</h2>
        <p class="proof-body">
          Since 1985, KRUPS Automation has designed, built, and commissioned
          conveyor systems for the most demanding assembly environments in
          automotive and industrial manufacturing.
        </p>
        <a href="/unternehmen" class="btn btn-ghost">About the company <span class="card-arrow">→</span></a>
      </div>
    </div>
  </section>

  <!-- ════ 4. PRODUCTS ════ -->
  <section class="products" id="systems">
    <div class="container">
      <div class="products-header">
        <div>
          <div class="products-eyebrow">Product systems</div>
          <h2>Two platforms.<br>Every assembly challenge.</h2>
        </div>
        <p class="products-header-right">
          From lightweight components to heavy battery packs —
          a complete conveyor portfolio from a single manufacturer.
        </p>
      </div>

      <div class="products-grid">
        <a class="product-card featured" href="/produkte/ecart">
          <div class="card-tag">Flagship System</div>
          <h3>LOGO!MAT eCart</h3>
          <p>
            Electrically driven, rail-guided workpiece carriers for precision
            assembly automation. Each cart carries its own drive, controls, and
            power — eliminating the central drive chains that make conventional
            conveyors complex and failure-prone.
          </p>
          <div class="card-specs">
            <span class="spec-chip">300 – 2.000 kg</span>
            <span class="spec-chip">±0,1 mm</span>
            <span class="spec-chip">ESD-safe</span>
            <span class="spec-chip">No WiFi</span>
            <span class="spec-chip">Active braking</span>
          </div>
          <div class="card-visual">
            <svg class="card-track-svg" viewBox="0 0 600 260" fill="none" xmlns="http://www.w3.org/2000/svg">
              <line x1="40" y1="76" x2="560" y2="76" stroke="#E8B500" stroke-width="1.5"/>
              <line x1="40" y1="184" x2="560" y2="184" stroke="#E8B500" stroke-width="1.5"/>
              <rect x="78" y="96" width="104" height="72" rx="5" stroke="#1A1A18" stroke-width="1.5" fill="none"/>
              <rect x="83" y="101" width="94" height="62" rx="3" stroke="#8A8680" stroke-width="1" fill="none"/>
              <circle cx="98" cy="184" r="7" stroke="#E8B500" stroke-width="1.5" fill="none"/>
              <circle cx="164" cy="184" r="7" stroke="#E8B500" stroke-width="1.5" fill="none"/>
              <rect x="244" y="96" width="104" height="72" rx="5" stroke="#1A1A18" stroke-width="1.5" fill="none"/>
              <rect x="249" y="101" width="94" height="62" rx="3" stroke="#8A8680" stroke-width="1" fill="none"/>
              <circle cx="264" cy="184" r="7" stroke="#E8B500" stroke-width="1.5" fill="none"/>
              <circle cx="330" cy="184" r="7" stroke="#E8B500" stroke-width="1.5" fill="none"/>
              <rect x="410" y="96" width="104" height="72" rx="5" stroke="#1A1A18" stroke-width="1.5" fill="none"/>
              <rect x="415" y="101" width="94" height="62" rx="3" stroke="#8A8680" stroke-width="1" fill="none"/>
              <circle cx="430" cy="184" r="7" stroke="#E8B500" stroke-width="1.5" fill="none"/>
              <circle cx="496" cy="184" r="7" stroke="#E8B500" stroke-width="1.5" fill="none"/>
              <line x1="204" y1="64" x2="204" y2="196" stroke="#8A8680" stroke-width="1" stroke-dasharray="3 4"/>
              <line x1="370" y1="64" x2="370" y2="196" stroke="#8A8680" stroke-width="1" stroke-dasharray="3 4"/>
              <path d="M544 130 L558 130 L551 123 M558 130 L551 137" stroke="#E8B500" stroke-width="1.5" stroke-linecap="round"/>
              <text x="204" y="56" text-anchor="middle" font-family="JetBrains Mono, ui-monospace, 'Courier New', monospace" font-size="9" fill="#8A8680" letter-spacing="0.5">STA 01</text>
              <text x="370" y="56" text-anchor="middle" font-family="JetBrains Mono, ui-monospace, 'Courier New', monospace" font-size="9" fill="#8A8680" letter-spacing="0.5">STA 02</text>
            </svg>
            <span class="card-visual-label">eCart V3 — Rail system schematic</span>
          </div>
          <span class="card-link">Explore LOGO!MAT eCart <span class="card-arrow">→</span></span>
        </a>

        <a class="product-card" href="/produkte/friktionsrollenfoerderer">
          <div class="card-tag">Proven Platform</div>
          <h3>Friktionsrollen&shy;förderer</h3>
          <p>
            Friction roller conveyors for continuous material flow in assembly
            and test lines. Simple, robust, field-proven across decades. Available
            in L, XL, and T-Serie.
          </p>
          <div class="card-specs">
            <span class="spec-chip">50 – 600 kg</span>
            <span class="spec-chip">L / XL / T-Serie</span>
            <span class="spec-chip">Oil-resistant</span>
          </div>
          <span class="card-link">Explore Friktionsförderer <span class="card-arrow">→</span></span>
        </a>

        <a class="product-card" href="/kontakt">
          <div class="card-tag">Custom Engineering</div>
          <h3>Sonder&shy;entwicklungen</h3>
          <p>
            When standard systems don't fit — we engineer from scratch.
            100% in-house manufacturing means every custom requirement
            is realized with full KRUPS quality and support.
          </p>
          <div class="card-specs">
            <span class="spec-chip">Project-specific</span>
            <span class="spec-chip">Full lifecycle</span>
          </div>
          <span class="card-link">Discuss your project <span class="card-arrow">→</span></span>
        </a>
      </div>
    </div>
  </section>

  <!-- ════ 5. WHY ════ -->
  <section class="why">
    <div class="container">
      <div class="why-header">
        <h2>Six reasons plant engineers<br>specify <em>LOGO!MAT.</em></h2>
        <p class="why-header-right">
          Every claim comes from a customer project report.
          Not marketing copy — engineering decisions made by
          production planners who ran the numbers.
        </p>
      </div>

      <div class="why-rows">
        <div class="why-row">
          <div class="why-claim">Commissioning in days, not weeks.</div>
          <div class="why-detail">UDP interfaces and pre-wired modules reduce electrical engineering to a fraction of conventional systems. <strong>Customers report setup teams completing installations their engineers expected to take weeks — in days.</strong></div>
        </div>
        <div class="why-row">
          <div class="why-claim">Active braking — real safety.</div>
          <div class="why-detail">The cart absorbs kinetic energy on E-stop. A friction clutch limits drive force; it doesn't stop a moving load. <strong>eCart can decelerate safely at a station even with the station's safety circuit open.</strong></div>
        </div>
        <div class="why-row">
          <div class="why-claim">30% of conventional conveyor energy.</div>
          <div class="why-detail">Measured by customers in operational plants. Short motor-on cycles and no continuous chain drive make the difference. <strong>Less running time on moving parts means lower wear and longer service intervals.</strong></div>
        </div>
        <div class="why-row">
          <div class="why-claim">No WiFi dependency.</div>
          <div class="why-detail">Rail-guided, cable-tethered control eliminates transmission errors from WiFi interference, construction activity, or neighbouring networks. <strong>No startup delays after E-stops that affect AGV fleets on WiFi.</strong></div>
        </div>
        <div class="why-row">
          <div class="why-claim">±0,1 mm stop accuracy, every cycle.</div>
          <div class="why-detail">Servo-driven positioning on rail with integrated stopper units. AGVs vary by millimetres depending on floor flatness, load distribution, and battery charge. <strong>Consistent stop position is not optional in battery assembly.</strong></div>
        </div>
        <div class="why-row">
          <div class="why-claim">Reconfigured in hours.</div>
          <div class="why-detail">Track layout changes — adding stations, reversing loops, splitting lines — require hours of mechanical work and minimal PLC reprogramming. <strong>Changes can be pre-tested in a digital twin before touching the live line.</strong></div>
        </div>
      </div>

      <div class="why-footer">
        <a href="/ressourcen/ecart-vs-agv" class="btn btn-ghost-light">Read the full eCart vs. AGV comparison →</a>
      </div>
    </div>
  </section>

  <!-- ════ 6. INDUSTRIES ════ -->
  <section class="industries">
    <div class="container">
      <div class="industries-header">
        <h2>Where KRUPS systems run.</h2>
        <p class="sub">
          From battery module assembly at giga-scale to precision drivetrain
          test benches — the load range and flexibility of LOGO!MAT covers
          the most demanding applications in industry.
        </p>
      </div>

      <div class="industry-list">
        <a class="industry-row featured" href="/branchen/batteriemontage">
          <div class="industry-num">01</div>
          <div class="industry-body">
            <h3>E-Mobilität &amp; Batteriemontage</h3>
            <p>Battery module and pack assembly for 48V to 800V platforms. Precise positioning for cell-to-module and module-to-pack processes, with ESD-safe cart construction throughout.</p>
          </div>
          <div class="industry-meta">
            <span class="payload">300 – 800 kg</span>
            <span class="clients">BMW · Volkswagen<br>Tesla · Porsche</span>
          </div>
        </a>
        <a class="industry-row" href="/branchen/antriebsstrang">
          <div class="industry-num">02</div>
          <div class="industry-body">
            <h3>Automotive Antriebsstrang</h3>
            <p>Engine, gearbox, and axle assembly lines where precision and cycle time consistency are non-negotiable production parameters.</p>
          </div>
          <div class="industry-meta">
            <span class="payload">200 – 1.500 kg</span>
            <span class="clients">Porsche · Audi · ZF</span>
          </div>
        </a>
        <a class="industry-row" href="/branchen/pruef-testautomation">
          <div class="industry-num">03</div>
          <div class="industry-body">
            <h3>Prüf- &amp; Testautomation</h3>
            <p>Conveyor integration with test benches and measurement stations. Repeatable positioning critical for automated test logging and traceability.</p>
          </div>
          <div class="industry-meta">
            <span class="payload">100 – 600 kg</span>
            <span class="clients">ZF · Bosch</span>
          </div>
        </a>
        <a class="industry-row" href="/branchen/nutzfahrzeuge-schwermontage">
          <div class="industry-num">04</div>
          <div class="industry-body">
            <h3>Nutzfahrzeuge &amp; Schwermontage</h3>
            <p>Commercial vehicle frames, large sub-assemblies, and industrial machinery — where payload requirements exceed what standard conveyor systems can handle.</p>
          </div>
          <div class="industry-meta">
            <span class="payload">Up to 2.000 kg</span>
            <span class="clients">Custom frames</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ════ 7. TECH COMPARISON ════ -->
  <section class="tech-band">
    <div class="container">
      <div class="tech-band-inner">
        <div class="tech-band-text">
          <div class="tech-eyebrow">Technology comparison</div>
          <h2>eCart vs. AGV vs. Chain Conveyor.</h2>
          <p class="intro">
            Three technologies compete for the same assembly floor space.
            The right choice depends on your payload, takt time, and
            infrastructure constraints.
          </p>
          <a href="/ressourcen/technologievergleich" class="btn btn-ghost">Full comparison guide →</a>
        </div>

        <div class="tech-comparison">
          <div class="comparison-header">
            <span>Criterion</span>
            <span>eCart</span>
            <span>AGV</span>
            <span>Chain</span>
          </div>
          <div class="comparison-row"><span class="attr">Stop accuracy</span><span class="val val-accent">±0,1 mm</span><span class="val val-neutral">±5–30 mm</span><span class="val val-neutral">±1–5 mm</span></div>
          <div class="comparison-row"><span class="attr">Commissioning</span><span class="val val-accent">Days</span><span class="val val-neutral">Weeks</span><span class="val val-neutral">Weeks</span></div>
          <div class="comparison-row"><span class="attr">Energy use</span><span class="val val-accent">Low</span><span class="val val-neutral">Medium</span><span class="val val-no">High</span></div>
          <div class="comparison-row"><span class="attr">Network required</span><span class="val val-yes">None</span><span class="val val-no">WiFi</span><span class="val val-yes">None</span></div>
          <div class="comparison-row"><span class="attr">Active braking</span><span class="val val-yes">Yes</span><span class="val val-yes">Yes</span><span class="val val-no">No</span></div>
          <div class="comparison-row"><span class="attr">Reconfiguration</span><span class="val val-accent">Hours</span><span class="val val-neutral">Days</span><span class="val val-no">Weeks</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ════ 8. FOOTER CTA ════ -->
  <section class="footer-cta" id="contact">
    <div class="footer-cta-bg"></div>
    <div class="container footer-cta-content">
      <div class="footer-cta-eyebrow">Start a conversation</div>
      <h2>Let's engineer<br><em>your next line.</em></h2>
      <p>
        From concept to commissioning. Tell us about your project
        and we'll show you what's possible.
      </p>
      <div class="footer-cta-btns">
        <a href="/kontakt" class="btn btn-accent">Request a Project →</a>
        <a href="/downloads/ecart-broschuere" class="btn btn-ghost-light">Download product brochure</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ───── Local tokens ───── */
  :root {
    --dark-text-strong: color-mix(in srgb, var(--color-dark-text) 70%, transparent);
    --dark-text-subtle: color-mix(in srgb, var(--color-dark-text) 42%, transparent);
    --dark-border: rgba(255, 255, 255, 0.07);
  }

  /* ───── Layout helper ───── */
  .container {
    max-width: var(--content-max);
    margin: 0 auto;
    padding: 0 64px;
  }

  /* ───── Button variants (page-scoped) ───── */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 13px 26px;
    border-radius: var(--radius-pill);
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    line-height: 1;
    cursor: pointer;
    transition: background-color 180ms ease, border-color 180ms ease, color 180ms ease;
    white-space: nowrap;
    border: none;
    letter-spacing: 0.1px;
  }
  .btn-dark { background: var(--color-text); color: var(--color-bg); }
  .btn-dark:hover { background: #333; }
  .btn-accent { background: var(--color-accent); color: var(--color-text); }
  .btn-accent:hover { background: var(--color-accent-hover); }
  .btn-ghost { background: transparent; color: var(--color-text); border: 1px solid var(--color-border); }
  .btn-ghost:hover { border-color: var(--color-text); }
  .btn-ghost-light { background: transparent; color: var(--color-dark-text); border: 1px solid rgba(232, 228, 221, 0.25); }
  .btn-ghost-light:hover { border-color: rgba(232, 228, 221, 0.6); }

  /* ───── 1. HERO ───── */
  .hero {
    min-height: 100vh;
    position: relative;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: var(--color-bg);
  }
  .hero-fade {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 80% 30%, rgba(232, 181, 0, 0.05) 0%, transparent 50%),
      linear-gradient(180deg, rgba(242, 239, 234, 0.6) 0%, transparent 20%, transparent 80%, rgba(242, 239, 234, 0.4) 100%);
    pointer-events: none;
  }
  .hero-content {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: var(--content-max);
    margin: 0 auto;
    padding: 160px 64px 96px;
  }
  .hero-eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .hero-eyebrow::before {
    content: '';
    display: block;
    width: 24px;
    height: 1px;
    background: var(--color-accent);
    flex-shrink: 0;
  }
  .hero h1 {
    font-family: var(--font-heading);
    font-size: clamp(56px, 6.5vw, 88px);
    font-weight: 600;
    line-height: 1;
    letter-spacing: 0;
    color: var(--color-text);
    max-width: 620px;
    margin-bottom: 28px;
  }
  .hero h1 em { font-style: italic; color: var(--color-muted); }
  .hero-sub {
    font-size: 18px;
    color: var(--color-muted);
    max-width: 420px;
    line-height: 1.65;
    margin-bottom: 36px;
  }
  .hero-ctas { display: flex; gap: 12px; margin-bottom: 56px; flex-wrap: wrap; }
  .hero-stats {
    display: flex;
    gap: 28px;
    align-items: center;
    padding-top: 32px;
    border-top: 1px solid var(--color-border);
    max-width: 520px;
    flex-wrap: wrap;
  }
  .hero-stat { display: flex; flex-direction: column; gap: 3px; }
  .hero-stat .val {
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 600;
    color: var(--color-text);
  }
  .hero-stat .lbl {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  .hero-stat-sep { width: 1px; height: 28px; background: var(--color-border); flex-shrink: 0; }

  /* ───── 2. TRUST BAR ───── */
  .trust-bar {
    background: var(--color-dark-bg);
    padding: 32px 0;
    border-top: 1px solid rgba(255, 255, 255, 0.03);
  }
  .trust-bar-inner {
    display: flex;
    align-items: center;
    gap: 48px;
    max-width: var(--content-max);
    margin: 0 auto;
    padding: 0 64px;
    flex-wrap: wrap;
  }
  .trust-bar-label {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--color-dark-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .trust-sep { width: 1px; height: 16px; background: rgba(255, 255, 255, 0.08); flex-shrink: 0; }
  .trust-logos { display: flex; align-items: center; gap: 40px; flex-wrap: wrap; }
  .trust-logo {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1.8px;
    text-transform: uppercase;
    color: var(--color-dark-text);
    opacity: 0.3;
    transition: opacity 200ms;
    white-space: nowrap;
  }
  .trust-logo:hover { opacity: 0.65; }

  /* ───── 3. PROOF ───── */
  .proof-alt { background: var(--color-bg); padding: 120px 0; }
  .proof-alt-strip {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    padding-bottom: 56px;
    margin-bottom: 64px;
    border-bottom: 1px solid var(--color-border);
  }
  .proof-alt-item {
    padding-right: 32px;
    border-right: 1px solid var(--color-border);
  }
  .proof-alt-item:last-child { border-right: none; }
  .proof-alt-item + .proof-alt-item { padding-left: 32px; }
  .proof-alt-num {
    display: block;
    font-family: var(--font-heading);
    font-size: clamp(52px, 5.5vw, 80px);
    font-weight: 600;
    line-height: 1;
    color: var(--color-accent);
    margin-bottom: 12px;
    white-space: nowrap;
  }
  .proof-alt-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--color-muted);
    line-height: 1.5;
  }
  .proof-alt-bottom { max-width: 760px; }
  .proof-headline {
    font-family: var(--font-heading);
    font-size: clamp(36px, 3.5vw, 52px);
    font-weight: 600;
    line-height: 1.05;
    margin-bottom: 20px;
  }
  .proof-body {
    font-size: 16px;
    color: var(--color-muted);
    line-height: 1.7;
    margin-bottom: 32px;
  }

  /* ───── 4. PRODUCTS ───── */
  .products { background: var(--color-surface); padding: 120px 0; }
  .products-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
